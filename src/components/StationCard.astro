---
import MuralArt from "./MuralArt.astro";
import { splitList, availability, type Station } from "../lib/content";
interface Props { station: Station; revealDelay?: number; }
const { station, revealDelay = 0 } = Astro.props;
const a = availability(station);
const chargers = splitList(station.chargerTypes);
const amenities = splitList(station.amenities);
const mapsHref = `https://www.google.com/maps/search/?api=1&query=${station.lat},${station.lng}`;
const toneClass = a.tone === "open" ? "avail-open" : a.tone === "limited" ? "avail-limited" : "avail-busy";
---
<article class="card reveal flex flex-col" data-reveal-delay={revealDelay}>
  <div class="relative">
    <MuralArt seed={station.slug} label={`Mural at ${station.name}`} ratio="16 / 10" />
    <span class={`availability ${toneClass}`}>
      <span class="dot" aria-hidden="true"></span>
      {a.avail} of {a.total} free
    </span>
  </div>
  <div class="card-charge"><i></i></div>
  <div class="p-5 flex flex-col gap-3 grow">
    <div>
      <p class="kicker mb-1">{station.neighborhood}</p>
      <h3 class="font-display font-bold text-xl leading-tight">{station.name}</h3>
    </div>
    <div class="flex flex-wrap gap-1.5">
      {chargers.map((c) => <span class="chip">{c}</span>)}
    </div>
    <p class="text-sm text-mute"><strong class="text-ink font-semibold">{station.chargerCount} chargers</strong> · {station.status}</p>
    <p class="text-sm text-mute line-clamp-2">{amenities.slice(0, 4).join(" · ")}</p>
    <p class="text-xs text-mute italic line-clamp-2">{station.muralArtist}</p>
    <div class="mt-auto pt-2 flex items-center justify-between">
      <span class="text-sm font-medium text-primary">R$ {station.pricePerKwh?.toFixed(2)}/kWh</span>
      <a href={mapsHref} target="_blank" rel="noopener" class="btn-secondary !py-2 !px-4 text-sm">Get directions</a>
    </div>
  </div>
</article>

<style>
  .chip {
    font-size: 0.7rem; font-weight: 600; letter-spacing: 0.02em;
    padding: 0.2rem 0.6rem; border-radius: 999px;
    background: var(--color-cream); color: var(--color-primary-deep);
    border: 1px solid var(--color-rule);
  }
  .availability {
    position: absolute; top: 0.75rem; right: 0.75rem;
    display: inline-flex; align-items: center; gap: 0.4rem;
    font-size: 0.72rem; font-weight: 600;
    padding: 0.3rem 0.65rem; border-radius: 999px;
    background: color-mix(in srgb, var(--color-ink) 82%, transparent);
    color: #fff; backdrop-filter: blur(4px);
  }
  .availability .dot { width: 0.5rem; height: 0.5rem; border-radius: 999px; }
  .avail-open .dot { background: #4ADE80; box-shadow: 0 0 0 3px color-mix(in srgb, #4ADE80 35%, transparent); }
  .avail-limited .dot { background: var(--color-amber); box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-amber) 35%, transparent); }
  .avail-busy .dot { background: #F87171; }
  .line-clamp-2 { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
</style>
