---
const quickLinks = [
  { href: "/", label: "Home" },
  { href: "/stations", label: "Stations" },
  { href: "/test-drives", label: "Test Drives" },
  { href: "/blog", label: "EV Journal" },
  { href: "/membership", label: "Membership" },
  { href: "/about", label: "About" },
  { href: "/contact", label: "Contact" },
];
---
<footer class="site-footer" transition:persist="site-footer">
  <div class="wrap py-14 grid gap-10 md:grid-cols-4">
    <!-- 1 · Brand + contact -->
    <div class="flex flex-col gap-4">
      <a href="/" class="flex items-center gap-2 font-display font-bold text-lg text-on-dark" aria-label="Estrada EV Hub home">
        <span class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-amber text-ink text-sm" aria-hidden="true">⚡</span>
        Estrada EV Hub
      </a>
      <p class="text-sm text-on-dark/70 max-w-xs">Charge forward, drive cleaner. Fast charging with co-working lounges and local coffee across São Paulo.</p>
      <address class="not-italic text-sm text-on-dark/80 flex flex-col gap-1.5">
        <a href="mailto:hello@estradaevhub.com.br" class="hover:text-amber transition-colors">hello@estradaevhub.com.br</a>
        <a href="tel:+551134567890" class="hover:text-amber transition-colors">+55 11 3456-7890</a>
        <span>Rua Aspicuelta 322, Vila Madalena<br />São Paulo – SP, 05433-010</span>
      </address>
    </div>

    <!-- 2 · Quick links -->
    <nav aria-label="Footer">
      <h2 class="kicker text-amber mb-4">Explore</h2>
      <ul class="flex flex-col gap-2.5 text-sm text-on-dark/80">
        {quickLinks.map((l) => (
          <li><a href={l.href} class="hover:text-amber transition-colors">{l.label}</a></li>
        ))}
      </ul>
    </nav>

    <!-- 3 · Social -->
    <div>
      <h2 class="kicker text-amber mb-4">Follow</h2>
      <ul class="flex flex-col gap-2.5 text-sm text-on-dark/80">
        <li>
          <a href="https://instagram.com/estradaevhub" class="inline-flex items-center gap-2 hover:text-amber transition-colors" rel="me noopener" target="_blank">
            <span aria-hidden="true">📷</span> @estradaevhub
          </a>
        </li>
        <li>
          <a href="https://x.com/estradaev" class="inline-flex items-center gap-2 hover:text-amber transition-colors" rel="me noopener" target="_blank">
            <span aria-hidden="true">✕</span> @estradaev
          </a>
        </li>
      </ul>
    </div>

    <!-- 4 · Legal + CTA -->
    <div class="flex flex-col gap-4">
      <h2 class="kicker text-amber mb-0">Legal</h2>
      <ul class="flex flex-col gap-2.5 text-sm text-on-dark/80">
        <li><a href="/privacy" class="hover:text-amber transition-colors">Privacy Policy</a></li>
        <li><a href="/terms" class="hover:text-amber transition-colors">Terms &amp; Conditions</a></li>
      </ul>
      <a href="/test-drives" class="btn-cta !py-2.5 !px-4 text-sm self-start mt-1">Book a test drive</a>
    </div>
  </div>

  <div class="border-t border-on-dark/15">
    <div class="wrap py-5 flex flex-col sm:flex-row items-center justify-between gap-2 text-xs text-on-dark/60">
      <p>© 2025 Estrada EV Hub.</p>
      <p>
        Powered by
        <a href="https://www.wix.com/lp-en/headless" class="text-amber hover:underline" rel="noopener" target="_blank">Wix Headless</a>
      </p>
    </div>
  </div>
</footer>
