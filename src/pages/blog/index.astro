---
import Layout from "../../layouts/Layout.astro";
import JsonLd from "../../components/JsonLd.astro";
import MuralArt from "../../components/MuralArt.astro";
import { posts, fmtDate } from "../../data/journal";

const categories = ["Market news", "Charging tips", "Driver stories"] as const;

// Category filter — read from the query string, filter server-side.
const activeCategory = Astro.url.searchParams.get("category");
const isActive = (cat: string | null) => activeCategory === cat;
const visiblePosts = activeCategory
  ? posts.filter((p) => p.category === activeCategory)
  : posts;

const filters = [
  { label: "All", value: null as string | null },
  ...categories.map((c) => ({ label: c, value: c as string | null })),
];

const blogSchema = {
  "@context": "https://schema.org",
  "@type": "Blog",
  name: "EV Journal · Estrada EV Hub",
  description:
    "Brazilian EV market news, charging tips, and driver stories from Estrada EV Hub.",
  url: "https://estradaevhub.com.br/blog",
  blogPost: posts.map((p) => ({
    "@type": "BlogPosting",
    headline: p.title,
    datePublished: p.date,
    author: { "@type": "Person", name: p.author },
    url: `https://estradaevhub.com.br/blog/${p.slug}`,
  })),
};
---

<Layout
  title="EV Journal"
  description="Brazilian EV market news, charging tips, and driver stories from Estrada EV Hub."
>
  <JsonLd slot="head" data={blogSchema} />

  <!-- charge bar: page-scroll signature device -->
  <div class="charge-track"><div class="charge-fill"></div></div>

  <!-- HEADER -->
  <section class="section">
    <div class="wrap">
      <div class="max-w-2xl reveal">
        <p class="kicker mb-3">EV Journal</p>
        <h1 class="font-display font-bold text-4xl md:text-5xl leading-[1.05]">
          Range, rates &amp; real stories
        </h1>
        <p class="mt-4 text-mute text-lg">
          Market news, charging tips, and driver stories from the streets of São Paulo.
        </p>
      </div>

      <!-- CATEGORY FILTER -->
      <nav class="mt-8 flex flex-wrap gap-2.5 reveal" aria-label="Filter posts by category">
        {filters.map((f) => (
          <a
            href={f.value ? `?category=${encodeURIComponent(f.value)}` : "/blog"}
            aria-current={isActive(f.value) ? "true" : undefined}
            class={`inline-flex items-center rounded-full px-4 py-1.5 text-sm font-medium transition-colors ${
              isActive(f.value)
                ? "bg-primary text-white"
                : "border border-rule text-ink hover:border-primary hover:text-primary"
            }`}
          >
            {f.label}
          </a>
        ))}
      </nav>

      <!-- POST GRID -->
      <div class="mt-10 grid gap-6 sm:grid-cols-2 md:grid-cols-3">
        {visiblePosts.map((p, i) => (
          <a
            href={`/blog/${p.slug}`}
            class="card reveal overflow-hidden group"
            data-reveal-delay={(i % 3) * 100}
          >
            <div class="relative">
              <MuralArt seed={p.slug} label={`Mural cover for: ${p.title}`} ratio="16 / 9" />
              <span class="absolute top-3 left-3 bg-paper text-primary-deep text-xs font-semibold px-2.5 py-1 rounded-full">
                {p.category}
              </span>
            </div>
            <div class="p-6">
              <p class="text-xs text-mute">
                <time datetime={p.date}>{fmtDate(p.date)}</time> · {p.readMins} min read
              </p>
              <h3 class="font-display font-bold text-xl mt-1 leading-tight group-hover:text-primary transition-colors">
                {p.title}
              </h3>
              <p
                class="text-mute text-sm mt-2"
                style="display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden"
              >
                {p.excerpt}
              </p>
            </div>
          </a>
        ))}
      </div>

      {visiblePosts.length === 0 && (
        <p class="mt-10 text-mute">No posts in this category yet. <a href="/blog" class="text-primary underline">See all posts.</a></p>
      )}
    </div>
  </section>

  <!-- CLOSING CTA BAND -->
  <section class="section bg-ink text-on-dark">
    <div class="wrap flex flex-col md:flex-row md:items-center md:justify-between gap-6">
      <div class="max-w-xl reveal">
        <p class="kicker mb-2 !text-amber">Ready when you are</p>
        <h2 class="font-display font-bold text-3xl md:text-4xl text-on-dark">
          Reading about it beats guessing. Driving it beats both.
        </h2>
        <p class="mt-3 text-on-dark/70 text-lg">
          Book a free Saturday test drive from our Vila Madalena flagship.
        </p>
      </div>
      <a href="/test-drives" class="btn-cta reveal shrink-0">Book a test drive</a>
    </div>
  </section>
</Layout>
