---
import Layout from "../layouts/Layout.astro";
import JsonLd from "../components/JsonLd.astro";
import ContactForm from "../components/react/ContactForm.tsx";
import { site } from "../data/site";

const topic = Astro.url.searchParams.get("topic") ?? "";
const mapsHref = `https://www.google.com/maps/search/?api=1&query=${site.geo.lat},${site.geo.lng}`;
const mapEmbed = `https://www.google.com/maps?q=${encodeURIComponent(site.address.street + ", " + site.address.neighborhood + ", São Paulo")}&z=15&output=embed`;

const contactSchema = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  mainEntity: {
    "@type": "AutomotiveBusiness",
    name: site.name,
    email: site.email,
    telephone: site.phone,
    address: {
      "@type": "PostalAddress",
      streetAddress: site.address.street,
      addressLocality: site.address.city,
      addressRegion: site.address.region,
      postalCode: site.address.postalCode,
      addressCountry: site.address.country,
    },
  },
};
---

<Layout
  title="Contact & fleet partnerships"
  description="Reach the Estrada EV Hub team about fleet charging accounts, corporate partnerships, or a question. Flagship at Rua Aspicuelta 322, Vila Madalena, São Paulo."
>
  <JsonLd slot="head" data={contactSchema} />
  <div class="charge-track"><div class="charge-fill"></div></div>

  <section class="section pb-8">
    <div class="wrap">
      <div class="eyebrow-line mb-4"></div>
      <h1 class="font-display font-bold text-4xl md:text-5xl max-w-3xl">
        {topic === "fleet" ? "Set up a fleet charging account" : "Let's talk"}
      </h1>
      <p class="mt-4 text-lg text-mute max-w-2xl">
        Fleet accounts, corporate partnerships, or a simple question — send a message and the right person will get back to you.
      </p>
    </div>
  </section>

  <section class="pb-12">
    <div class="wrap grid gap-10 lg:grid-cols-5 items-start">
      <!-- details -->
      <div class="lg:col-span-2 flex flex-col gap-6">
        <div class="card p-6">
          <p class="kicker mb-3">Flagship</p>
          <address class="not-italic flex flex-col gap-3 text-sm">
            <a href={`mailto:${site.email}`} class="flex items-center gap-3 hover:text-primary transition-colors">
              <span aria-hidden="true">✉️</span> {site.email}
            </a>
            <a href={`tel:${site.phoneHref}`} class="flex items-center gap-3 hover:text-primary transition-colors">
              <span aria-hidden="true">📞</span> {site.phone}
            </a>
            <span class="flex items-start gap-3">
              <span aria-hidden="true">📍</span>
              <span>{site.address.street}, {site.address.neighborhood}<br />{site.address.city} – {site.address.region}, {site.address.postalCode}</span>
            </span>
          </address>
          <a href={mapsHref} target="_blank" rel="noopener" class="btn-secondary !py-2 !px-4 text-sm mt-4">Get directions</a>
        </div>
        <div class="card overflow-hidden">
          <iframe title="Map to the Vila Madalena flagship" src={mapEmbed} loading="lazy" referrerpolicy="no-referrer-when-downgrade" style="width:100%;height:240px;border:0;display:block"></iframe>
        </div>
        <p class="text-sm text-mute">{site.hours}</p>
      </div>

      <!-- form -->
      <div class="lg:col-span-3">
        <ContactForm client:idle topic={topic} />
      </div>
    </div>
  </section>
</Layout>
