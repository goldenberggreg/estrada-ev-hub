---
import Layout from "../layouts/Layout.astro";
import { site } from "../data/site";
const sections = [
  { h: "What we collect", b: "Contact details you submit (name, email, phone), test-drive and membership requests, and charging-session data tied to your account. We do not sell your data or add you to a mailing list without consent." },
  { h: "How we use it", b: "To schedule test drives, operate your membership and charging history, process payments, and respond to inquiries. Fleet account data is used for billing and reporting only." },
  { h: "Your rights", b: "Under the LGPD you may access, correct, or delete your personal data at any time. Email us and we will action the request within the legal timeframe." },
  { h: "Contact", b: `Questions about privacy? Write to ${site.email}.` },
];
---
<Layout title="Privacy Policy" description="How Estrada EV Hub collects, uses, and protects your personal data under the LGPD." noindex={true}>
  <section class="section">
    <div class="wrap max-w-[48rem]">
      <div class="eyebrow-line mb-4"></div>
      <h1 class="font-display font-bold text-4xl">Privacy Policy</h1>
      <p class="mt-3 text-mute">Last updated 2025. This is a summary for the demo build.</p>
      <div class="mt-8 flex flex-col gap-8">
        {sections.map((s) => (
          <div>
            <h2 class="font-display font-bold text-xl mb-2">{s.h}</h2>
            <p class="text-mute leading-relaxed">{s.b}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>
